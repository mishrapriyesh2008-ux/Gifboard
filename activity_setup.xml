<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/keyboard_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_title"
        android:textColor="@color/key_text"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/step1Text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/setup_step1"
        android:textColor="@color/key_text"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/step2Text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/setup_step2"
        android:textColor="@color/search_hint_text"
        android:textSize="16sp" />

    <Button
        android:id="@+id/enableButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/accent"
        android:text="@string/enable_keyboard"
        android:textColor="@color/white" />

</LinearLayout>
