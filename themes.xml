<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.GifKeyboard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/keyboard_bg</item>
    </style>

    <!-- Theme applied to the IME window itself; no title bar, transparent edges -->
    <style name="Theme.GifKeyboard.Ime" parent="Theme.GifKeyboard">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
